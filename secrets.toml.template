# ╔══════════════════════════════════════════════════════════════════════╗
# ║  .streamlit/secrets.toml — TEMPLATE                                  ║
# ║                                                                      ║
# ║  انسخي هذا الملف باسم: secrets.toml (بدون .template)                 ║
# ║  ولا ترفعيه على GitHub أبداً.                                       ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 1) Google Sheet النظيف ────────────────────────────────────────────
[sheet]
sheet_id        = "PASTE_YOUR_SHEET_ID_HERE"
worksheet_name  = "Sheet1"

# ── 2) Google Drive (لرفع الصور المُولَّدة) ────────────────────────────
[drive]
folder_name = "Moarjam_AlRiyadh_Images"
# (اختياري) إذا لديك أكثر من مجلد بنفس الاسم، حدّدي ID المجلد بدل الاسم:
# folder_id = "1AbC...XYZ"

# ── 3) OpenAI (لـ Agent + توليد الصور) ────────────────────────────────
[openai]
api_key = "sk-..."

# ── 4) Google Service Account ────────────────────────────────────────
# انسخي القيم من ملف JSON من Google Cloud Console.
# مهم: نفس الـ client_email لازم يكون له صلاحية Editor على:
#   - Google Sheet
#   - مجلد Drive (Moarjam_AlRiyadh_Images)
[gcp_service_account]
type                        = "service_account"
project_id                  = "your-project-id"
private_key_id              = "abc123..."
private_key                 = """-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...
...PASTE_THE_ENTIRE_PRIVATE_KEY_INCLUDING_NEWLINES...
-----END PRIVATE KEY-----
"""
client_email                = "review-app@your-project.iam.gserviceaccount.com"
client_id                   = "1234567890..."
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/review-app%40your-project.iam.gserviceaccount.com"
universe_domain             = "googleapis.com"
